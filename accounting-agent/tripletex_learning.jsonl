{"id": "ttx-001", "language": "no", "prompt": "Opprett kunde: Nordlys AS (orgnr 915123456), e-post post@nordlys.no, adresse Karl Johans gate 1, 0154 Oslo. Faktureringsvaluta NOK, betalingsfrist 14 dager.", "normalized_task": {"intent": "create_customer", "entities": {"customer": {"name": "Nordlys AS", "orgNo": "915123456", "email": "post@nordlys.no", "address": {"street": "Karl Johans gate 1", "zip": "0154", "city": "Oslo", "country": "NO"}, "currency": "NOK", "paymentTermsDays": 14}}}, "api_plan": [{"op": "GET /customers", "params": {"orgNo": "915123456"}, "store_as": "existing_customer"}, {"op": "POST /customers", "body_from": "entities.customer", "guard": "existing_customer is None", "idempotencyKey": "hash(customer)"}, {"op": "GET /customers", "params": {"orgNo": "915123456"}, "assert_fields": ["name", "orgNo", "email", "address"]}], "expected_end_state": {"resource": "customer", "match_on": {"orgNo": "915123456"}, "fields": {"name": "Nordlys AS", "email": "post@nordlys.no", "address.city": "Oslo", "paymentTermsDays": 14}}, "policies": {"lookup_before_create": true, "strict_match": true}}
{"id": "ttx-002", "language": "en", "prompt": "Create an invoice for Acme Ltd (org 874223111). One line: Consulting hours x10 at 1200 NOK, VAT high. Due in 14 days.", "normalized_task": {"intent": "create_invoice", "entities": {"customer": {"name": "Acme Ltd", "orgNo": "874223111"}, "invoice": {"currency": "NOK", "dueDays": 14, "invoiceDate": "{{today}}"}, "lines": [{"productNumber": "CONS-001", "name": "Consulting hours", "qty": 10, "unitPrice": 1200.0, "vatCode": "HIGH"}]}}, "api_plan": [{"op": "GET /customers", "params": {"orgNo": "874223111"}, "store_as": "cust"}, {"op": "POST /customers", "body": {"name": "Acme Ltd", "orgNo": "874223111"}, "guard": "cust is None", "idempotencyKey": "hash(customer)"}, {"op": "GET /products", "params": {"productNumber": "CONS-001"}, "store_as": "prod"}, {"op": "POST /products", "body": {"productNumber": "CONS-001", "name": "Consulting hours", "vatCode": "HIGH"}, "guard": "prod is None"}, {"op": "POST /invoices", "body_from": "compose_invoice(customer, lines, invoice)"}, {"op": "GET /invoices/{id}", "store_as": "invoice"}], "expected_end_state": {"resource": "invoice", "fields": {"currency": "NOK", "dueDays": 14, "lines[0].qty": 10, "lines[0].vatCode": "HIGH"}}, "policies": {"verify_after_mutation": true, "minimal_calls": true}}
{"id": "ttx-003", "language": "de", "prompt": "Zahlung registrieren: Rechnung 10023 vollständig bezahlt am 2026-03-18, Betrag 12,000 NOK.", "normalized_task": {"intent": "register_payment", "entities": {"invoice": {"invoiceNumber": "10023", "currency": "NOK"}, "payment": {"amount": 12000.0, "date": "2026-03-18", "method": "bank"}}}, "api_plan": [{"op": "GET /invoices", "params": {"invoiceNumber": "10023"}, "store_as": "inv", "assert_exists": true}, {"op": "POST /payments", "body_from": "compose_payment(inv, payment)"}, {"op": "GET /invoices/{id}", "assert_fields": {"status": "paid"}}], "expected_end_state": {"resource": "invoice", "fields": {"status": "paid", "paidAmount": 12000.0}}}
{"id": "ttx-004", "language": "fr", "prompt": "Émettre un avoir pour la facture 10024 (erreur de prix). Créditer la totalité.", "normalized_task": {"intent": "issue_credit_note", "entities": {"invoice": {"invoiceNumber": "10024"}, "credit": {"scope": "full"}}}, "api_plan": [{"op": "GET /invoices", "params": {"invoiceNumber": "10024"}, "store_as": "inv"}, {"op": "POST /credit-notes", "body_from": "mirror_invoice(inv)"}, {"op": "GET /credit-notes/{id}", "assert_fields": ["total", "linkedInvoiceId"]}], "expected_end_state": {"resource": "creditNote", "fields": {"linkedInvoice.invoiceNumber": "10024"}}}
{"id": "ttx-005", "language": "es", "prompt": "Crear un proyecto 'Campaña Q2' vinculado al cliente Sol Nórdico SA (NIF 927441110).", "normalized_task": {"intent": "create_project", "entities": {"customer": {"name": "Sol Nórdico SA", "orgNo": "927441110"}, "project": {"name": "Campaña Q2"}}}, "api_plan": [{"op": "GET /customers", "params": {"orgNo": "927441110"}, "store_as": "cust"}, {"op": "POST /customers", "body": {"name": "Sol Nórdico SA", "orgNo": "927441110"}, "guard": "cust is None"}, {"op": "POST /projects", "body": {"name": "Campaña Q2", "customerId_from": "cust.id"}}, {"op": "GET /projects", "params": {"name": "Campaña Q2"}, "assert_fields": {"customer.name": "Sol Nórdico SA"}}], "expected_end_state": {"resource": "project", "fields": {"name": "Campaña Q2"}}}
{"id": "ttx-006", "language": "pt", "prompt": "Excluir relatório de despesas de viagem 'Lisboa Março' do funcionário joao@empresa.pt.", "normalized_task": {"intent": "delete_travel_expense_report", "entities": {"employee": {"email": "joao@empresa.pt"}, "expenseReport": {"name": "Lisboa Março"}}}, "api_plan": [{"op": "GET /employees", "params": {"email": "joao@empresa.pt"}, "store_as": "emp", "assert_exists": true}, {"op": "GET /travel-expenses", "params": {"name": "Lisboa Março", "employeeId_from": "emp.id"}, "store_as": "rep"}, {"op": "DELETE /travel-expenses/{id}", "guard": "rep is not None"}, {"op": "GET /travel-expenses", "params": {"name": "Lisboa Março", "employeeId_from": "emp.id"}, "assert_empty": true}], "expected_end_state": {"resource": "travelExpenseReport", "fields": {"deleted": true}}}
{"id": "ttx-007", "language": "nn", "prompt": "Opprett tilsett: Maria Øye (maria.oye@example.no). Gje ho rolle 'Rekneskap'.", "normalized_task": {"intent": "create_employee_and_set_role", "entities": {"employee": {"name": "Maria Øye", "email": "maria.oye@example.no"}, "role": "Accounting"}}, "api_plan": [{"op": "GET /employees", "params": {"email": "maria.oye@example.no"}, "store_as": "emp"}, {"op": "POST /employees", "body": {"name": "Maria Øye", "email": "maria.oye@example.no"}, "guard": "emp is None"}, {"op": "POST /employees/{id}/roles", "body": {"role": "Accounting"}}, {"op": "GET /employees/{id}", "assert_fields": {"roles[]": "Accounting"}}], "expected_end_state": {"resource": "employee", "fields": {"email": "maria.oye@example.no", "roles": ["Accounting"]}}}
{"id": "ttx-008", "language": "en", "prompt": "Enable department 'Sales' and use it on a new invoice to Borealis AS (org 912300111): 1x License 5000 NOK (high VAT).", "normalized_task": {"intent": "enable_department_and_invoice", "entities": {"department": {"name": "Sales", "enabled": true}, "customer": {"name": "Borealis AS", "orgNo": "912300111"}, "invoice": {"currency": "NOK", "invoiceDate": "{{today}}"}, "lines": [{"name": "License", "qty": 1, "unitPrice": 5000.0, "vatCode": "HIGH"}]}}, "api_plan": [{"op": "GET /departments", "params": {"name": "Sales"}, "store_as": "dept"}, {"op": "POST /departments", "body": {"name": "Sales", "enabled": true}, "guard": "dept is None"}, {"op": "PUT /departments/{id}", "body": {"enabled": true}, "guard": "dept.enabled is False"}, {"op": "UPSERT customer", "using": [{"op": "GET /customers", "params": {"orgNo": "912300111"}}, {"op": "POST /customers", "body": {"name": "Borealis AS", "orgNo": "912300111"}}]}, {"op": "POST /invoices", "body_from": "compose_invoice_with_department(customer, lines, invoice, dept)"}], "expected_end_state": {"resource": "invoice", "fields": {"department.name": "Sales", "lines[0].vatCode": "HIGH"}}, "policies": {"idempotent_create": true}}
